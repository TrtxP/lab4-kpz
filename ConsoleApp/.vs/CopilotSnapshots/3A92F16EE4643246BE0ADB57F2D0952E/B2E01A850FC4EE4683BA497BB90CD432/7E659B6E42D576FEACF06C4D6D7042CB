namespace DesignPatterns.Mediator
{
  public class CommandCentre
  {
    private List<Runway> _runways = new List<Runway>();
    private List<Aircraft> _aircrafts = new List<Aircraft>();
    public Runway? _currentRunway { get; set; }
    public Aircraft? _isBusyWithAircraft;
    public Dictionary<Aircraft, Runway> _activePlanes = new Dictionary<Aircraft, Runway>();

    public CommandCentre(Runway[] runways, Aircraft[] aircrafts)
    {
      foreach (var runway in runways)
      {
        runway.Mediator = this;
        _runways.Add(runway);
      }
      
      foreach (var aircraft in aircrafts)
      {
        aircraft.Mediator = this; 
        _aircrafts.Add(aircraft);
      }
    }

    public void RequestLanding(Aircraft aircraft)
    {
            Console.WriteLine($"Aircraft {aircraft.Name} is landing");
            Console.WriteLine("Checking runway");

            bool found = false; 

            foreach (var runway in _runways)
            {
                if (runway == _activePlanes.Values)
                {
                    this._isBusyWithAircraft = aircraft;
                    _activePlanes[aircraft] = runway;
                    runway.HighLightRed();
                    found = true;
                    Console.WriteLine($"Aircraft {aircraft.Name} has landed");
                    break;
                }
            }

            if (!found)
            {
                Console.WriteLine("Could not land, the runway is busy.");
            }
    }

    public void RequestTakeOff(Aircraft aircraft)
    {
            Console.WriteLine($"Aircraft {aircraft.Name} is taking off.");

            _activePlanes.Remove(aircraft, out var runway);

            if (runway != null)
            {
                this._isBusyWithAircraft = null;
                this._currentRunway = null;
                runway.HighLightGreen();
                Console.WriteLine($"Aircraft {aircraft.Name} has took off.");
            }
    }
  }
}